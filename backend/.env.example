# --- SMTP (your psitech.co.in / MailEnable mail server) ---
# Common MailEnable values — confirm with your hosting/control panel:
SMTP_HOST=mail.psitech.co.in
SMTP_PORT=587
SMTP_SECURE=false           # true if you use port 465, false for 587 (STARTTLS)
# Shared mail hosts present a cert for the provider domain, not mail.psitech.co.in.
# Keep this "false" so the encrypted connection works despite the hostname mismatch.
SMTP_TLS_REJECT_UNAUTHORIZED=false
SMTP_USER=partnerships@psitech.co.in
SMTP_PASS=CHANGE_ME         # the mailbox password for partnerships@psitech.co.in

# --- Delivery ---
MAIL_TO=partnerships@psitech.co.in
MAIL_FROM=partnerships@psitech.co.in   # usually same as SMTP_USER

# --- Server ---
PORT=3000
# Lock this down in production to your site's origin, e.g. https://pawlink.psitech.co.in
ALLOWED_ORIGIN=*
